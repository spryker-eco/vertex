{
    "name": "spryker-eco/vertex",
    "type": "library",
    "description": "Vertex module",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "psr/http-message": "^1.0.0",
        "spryker/calculation-extension": "^1.0.0",
        "spryker/glossary-storage": "^1.11.2",
        "spryker/glue-application": "^1.9.0",
        "spryker/glue-application-extension": "^1.0.0",
        "spryker/guzzle": "^2.4.1",
        "spryker/kernel": "^3.30.0",
        "spryker/log": "^3.0.0",
        "spryker/oms-extension": "^1.4.0",
        "spryker/ramsey-uuid": "^2.0.0",
        "spryker/sales": "^11.0.0",
        "spryker/store": "^1.16.0",
        "spryker/symfony": "^3.0.0",
        "spryker/transfer": "^3.27.0",
        "spryker/util-encoding": "^2.1.0",
        "spryker/zed-request": "^3.4.0"
    },
    "require-dev": {
        "spryker/calculation": "*",
        "spryker/code-sniffer": "*",
        "spryker/container": "*",
        "spryker/customer": "*",
        "spryker/merchant": "*",
        "spryker/merchant-profile": "*",
        "spryker/oms": "*",
        "spryker/propel": "*",
        "spryker/testify": "*"
    },
    "suggest": {
        "spryker/calculation": "If you want to use Calculation plugin.",
        "spryker/oms": "If you want to use VertexSubmitPaymentTaxInvoicePlugin"
    },
    "autoload": {
        "psr-4": {
            "SprykerEco\\": "src/SprykerEco/",
            "SprykerEcoTest\\Shared\\Vertex\\Helper\\": "tests/SprykerEcoTest/Shared/Vertex/_support/Helper/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SprykerEcoTest\\": "tests/SprykerEcoTest/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
